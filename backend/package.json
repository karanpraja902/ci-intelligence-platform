    "jsonwebtoken": "^9.0.2",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4",
    "@prisma/client": "^5.9.1",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "prisma": "^5.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
